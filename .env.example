# Supabase — Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...votre_cle_anon
# Clé secrète (seed, scripts) — PAS la clé anon / publishable
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Notifications — email (Resend) et push navigateur
RESEND_API_KEY=
RESEND_FROM_EMAIL=Meet & Match <notifications@votre-domaine.com>
# Générer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:contact@votre-domaine.com
# Secret partagé webhook Supabase → /api/webhooks/notifications
NOTIFICATION_WEBHOOK_SECRET=
# Secret Vercel Cron → /api/cron/notification-delivery
CRON_SECRET=

# Géocodage OpenStreetMap (optionnel — User-Agent requis par Nominatim)
GEOCODE_USER_AGENT=MeetAndMatch/1.0 (contact@votre-domaine.com)
